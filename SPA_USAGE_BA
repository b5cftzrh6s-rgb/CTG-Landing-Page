<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CTG CET — Streamlined SPA Request</title>
<script src="navbar.js" defer></script>
<style>
:root{
  --blue:#003a70;--blue-dark:#002347;--teal:#00a7b5;--orange:#e87722;
  --bg:#f4f6f9;--card:#fff;--border:#d6deea;--text:#1f2a3a;--muted:#5b6b80;
  --success:#127a4b;--danger:#b42318;--warning:#9a6700;--focus:#006fc9;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;font-family:"Segoe UI",Arial,sans-serif;background:var(--bg);color:var(--text)}
button,input,select,textarea{font:inherit}
.page-header{background:linear-gradient(135deg,var(--blue),var(--blue-dark));color:#fff;padding:36px 20px}
.page-header-inner{max-width:1160px;margin:auto;display:flex;justify-content:space-between;align-items:flex-start;gap:20px}
.page-header h1{margin:0;font-size:34px}
.page-header p{max-width:760px;margin:8px 0 0;color:#e5f0fb;line-height:1.55}
.status-pill{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.35);border-radius:999px;padding:8px 12px;font-size:13px;font-weight:700;white-space:nowrap}
main{max-width:1160px;margin:28px auto 48px;padding:0 20px}
.notice{display:flex;gap:12px;align-items:flex-start;background:#fff8e6;border:1px solid #e8c66a;border-left:5px solid var(--orange);border-radius:10px;padding:14px 16px;margin-bottom:20px;line-height:1.45}
.notice strong{color:#6b4700}
.progress{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin:0 0 20px}
.progress button{border:1px solid var(--border);background:#fff;color:var(--muted);border-radius:10px;padding:12px 10px;font-size:13px;font-weight:700;cursor:pointer;text-align:left}
.progress button.active{background:var(--blue);color:#fff;border-color:var(--blue)}
.progress button.done{background:#e9f7f0;color:#0f6841;border-color:#8ed0ae}
.progress .num{display:inline-grid;place-items:center;width:24px;height:24px;margin-right:7px;border-radius:50%;background:rgba(0,0,0,.08)}
.progress .active .num{background:rgba(255,255,255,.2)}
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;box-shadow:0 3px 12px rgba(0,35,71,.07);overflow:hidden}
.card-head{padding:22px 24px;border-bottom:1px solid var(--border);background:#fbfcfe}
.card-head h2{margin:0;color:var(--blue);font-size:24px}
.card-head p{margin:6px 0 0;color:var(--muted);line-height:1.5}
.card-body{padding:24px}
.step{display:none}.step.active{display:block}
.grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}
.full{grid-column:1/-1}
.field label,.field .label{display:block;margin-bottom:7px;font-weight:700;font-size:14px}
.req{color:var(--danger);margin-left:3px}
.hint{display:block;color:var(--muted);font-size:12px;margin-top:6px;line-height:1.4}
input,select,textarea{width:100%;border:1px solid #aebbc9;border-radius:8px;padding:11px 12px;background:#fff;color:var(--text)}
input:focus,select:focus,textarea:focus{outline:3px solid rgba(0,111,201,.18);border-color:var(--focus)}
textarea{min-height:100px;resize:vertical}
.choice-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}
.choice{position:relative}
.choice input{position:absolute;opacity:0;pointer-events:none}
.choice label{display:block;border:1px solid #aebbc9;border-radius:9px;padding:13px 12px;background:#fff;cursor:pointer;font-weight:700;text-align:center}
.choice input:checked+label{border-color:var(--teal);background:#e9f9fb;color:#005966;box-shadow:inset 0 0 0 1px var(--teal)}
.subsection{margin-top:22px;padding-top:22px;border-top:1px solid var(--border)}
.subsection h3{margin:0 0 14px;color:var(--blue);font-size:18px}
.product-list{display:grid;gap:14px}
.product{border:1px solid var(--border);border-radius:10px;background:#f9fbfd;padding:16px}
.product-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}
.product-top h3{margin:0;color:var(--blue);font-size:17px}
.product-grid{display:grid;grid-template-columns:1.2fr .9fr .7fr .75fr .8fr .85fr;gap:12px;align-items:end}
.product-grid .field label{font-size:12px}
.btn{border:0;border-radius:8px;padding:11px 16px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:7px;text-decoration:none}
.btn:disabled{opacity:.48;cursor:not-allowed}
.btn-primary{background:var(--blue);color:#fff}.btn-primary:hover{background:var(--blue-dark)}
.btn-success{background:var(--success);color:#fff}.btn-success:hover{background:#0d603a}
.btn-secondary{background:#fff;color:var(--blue);border:1px solid #9bb2c7}.btn-secondary:hover{background:#edf4fa}
.btn-danger{background:#fff;color:var(--danger);border:1px solid #e4a09a;padding:7px 10px;font-size:12px}
.actions{display:flex;justify-content:space-between;gap:12px;margin-top:24px;padding-top:20px;border-top:1px solid var(--border)}
.actions-right{display:flex;gap:10px;flex-wrap:wrap}
.review-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px}
.review-item{background:#f7f9fc;border:1px solid var(--border);border-radius:8px;padding:12px}
.review-item span{display:block;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.05em;font-weight:700}
.review-item strong{display:block;margin-top:4px;word-break:break-word}
.table-wrap{overflow:auto;border:1px solid var(--border);border-radius:9px}
table{width:100%;border-collapse:collapse;min-width:760px}
th,td{padding:10px 12px;border-bottom:1px solid var(--border);text-align:left;font-size:13px}
th{background:#eef3f8;color:var(--blue);font-size:12px;text-transform:uppercase;letter-spacing:.03em}
tr:last-child td{border-bottom:0}
.validation{display:none;margin-bottom:16px;background:#fff1f0;border:1px solid #f1a7a1;color:#7a1f19;border-radius:8px;padding:12px 14px}
.validation.show{display:block}
.success-box{background:#eaf8f1;border:1px solid #8fd0af;border-radius:10px;padding:18px;color:#0f5f3c;display:none;margin-top:18px}
.success-box.show{display:block}
.summary{white-space:pre-wrap;background:#f8fafc;border:1px solid var(--border);border-radius:8px;padding:14px;font:13px/1.5 Consolas,monospace;max-height:360px;overflow:auto}
.footer-note{text-align:center;color:var(--muted);font-size:12px;margin-top:20px;line-height:1.5}
.hidden{display:none!important}
@media(max-width:900px){.product-grid{grid-template-columns:repeat(2,1fr)}.page-header-inner{flex-direction:column}.review-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:650px){.grid,.choice-row,.review-grid{grid-template-columns:1fr}.product-grid{grid-template-columns:1fr}.progress{grid-template-columns:repeat(2,1fr)}.card-body,.card-head{padding:18px}.page-header h1{font-size:28px}.actions{align-items:stretch}.actions,.actions-right{flex-direction:column}.btn{width:100%}}
@media print{#navbar-container,.progress,.notice,.actions,.page-header .status-pill,.footer-note{display:none!important}.step{display:block!important}.card{box-shadow:none;border:0}.card-head{padding-left:0}.card-body{padding:0}}
</style>
</head>
<body>
<div id="navbar-container"></div>
<header class="page-header">
  <div class="page-header-inner">
    <div>
      <h1>CTG CET</h1>
      <p>Streamlined CTG request builder for new SPAs, SPA amendments, and one-time quotes. Only the fields needed for the selected request are shown.</p>
    </div>
    <div class="status-pill">CTG / Global High Tech</div>
  </div>
</header>
<main>
  <div class="notice">
    <div aria-hidden="true">⚠️</div>
    <div><strong>Tracked submission notice:</strong> This GitHub page prepares and validates the request, then opens a formatted Outlook email to GHTCET. It does not create an official Formsite tracking reference. Use the official Formsite button on the final step whenever tracked submission is required.</div>
  </div>

  <div class="progress" aria-label="Form progress">
    <button type="button" data-go="1" class="active"><span class="num">1</span>Customer</button>
    <button type="button" data-go="2"><span class="num">2</span>Request</button>
    <button type="button" data-go="3"><span class="num">3</span>Products</button>
    <button type="button" data-go="4"><span class="num">4</span>Review</button>
  </div>

  <section class="card" aria-live="polite">
    <div class="card-head">
      <h2 id="step-title">Customer and requestor</h2>
      <p id="step-subtitle">Basic information used in the CET subject line and routing.</p>
    </div>
    <div class="card-body">
      <div id="validation" class="validation" role="alert"></div>

      <div class="step active" data-step="1">
        <div class="grid">
          <div class="field"><label for="requestorName">Your name<span class="req">*</span></label><input id="requestorName" autocomplete="name" value="Charlie Fischer" required></div>
          <div class="field"><label for="requestorEmail">Your email<span class="req">*</span></label><input id="requestorEmail" type="email" autocomplete="email" value="charles.fischer@ecolab.com" required></div>
          <div class="field"><label for="district">District<span class="req">*</span></label><select id="district" required><option value="0T110">0T110</option><option value="0T112">0T112</option><option value="OTHER">Other CTG/GHT district</option></select></div>
          <div class="field"><label for="ccEmail">Additional email to copy</label><input id="ccEmail" type="email" placeholder="Optional"><span class="hint">Use a shared mailbox or stakeholder who needs visibility.</span></div>
          <div class="field"><label for="soldTo">Sold-to number<span class="req">*</span></label><input id="soldTo" inputmode="numeric" placeholder="Example: 1004101" required></div>
          <div class="field"><label for="accountName">Account name<span class="req">*</span></label><input id="accountName" placeholder="Customer name" required></div>
          <div class="field"><label for="government">Government customer?<span class="req">*</span></label><select id="government"><option>No</option><option>Yes</option></select></div>
          <div class="field"><label for="incoterms">Incoterms<span class="req">*</span></label><select id="incoterms"><option value="">Select...</option><option>DDP</option><option>FCA</option><option>EXW</option><option>DAP</option><option>Other</option></select></div>
        </div>
        <div class="actions"><span></span><div class="actions-right"><button class="btn btn-primary" type="button" data-next>Next: Request →</button></div></div>
      </div>

      <div class="step" data-step="2">
        <div class="field full">
          <span class="label">What do you need?<span class="req">*</span></span>
          <div class="choice-row">
            <div class="choice"><input type="radio" name="requestKind" id="newSpa" value="Setup New SPA"><label for="newSpa">Setup New SPA</label></div>
            <div class="choice"><input type="radio" name="requestKind" id="amendSpa" value="Amend Existing SPA" checked><label for="amendSpa">Amend Existing SPA</label></div>
            <div class="choice"><input type="radio" name="requestKind" id="oneTime" value="One-Time Quote"><label for="oneTime">One-Time Quote</label></div>
          </div>
        </div>

        <div id="newFields" class="subsection hidden">
          <h3>New SPA details</h3>
          <div class="grid">
            <div class="field"><label for="startDate">Start date<span class="req">*</span></label><input id="startDate" type="date"><span class="hint">Use the first day of the month when required by the current process.</span></div>
            <div class="field"><label for="endDate">End date<span class="req">*</span></label><input id="endDate" type="date"><span class="hint">Use the last day of the month when required by the current process.</span></div>
            <div class="field"><label for="renew">Will this renew?</label><select id="renew"><option>Yes</option><option>No</option></select></div>
            <div class="field"><label for="spaType">SPA type</label><select id="spaType"><option>On-going SPA</option><option>One-time SPA</option></select></div>
          </div>
        </div>

        <div id="amendFields" class="subsection">
          <h3>Existing SPA details</h3>
          <div class="grid">
            <div class="field"><label for="spaNumber">SPA number<span class="req">*</span></label><input id="spaNumber" placeholder="Example: 7402301"></div>
            <div class="field"><label for="effectiveDate">Effective date of change<span class="req">*</span></label><input id="effectiveDate" type="date"></div>
            <div class="field full"><span class="label">Amendment actions<span class="req">*</span></span><span class="hint" style="margin:0 0 8px">Select every action needed. Product-level actions can also be set on the next step.</span><div class="choice-row"><div class="choice"><input type="checkbox" id="actAdd" value="Add Product"><label for="actAdd">Add Product</label></div><div class="choice"><input type="checkbox" id="actRemove" value="Remove Product"><label for="actRemove">Remove Product</label></div><div class="choice"><input type="checkbox" id="actPrice" value="Price Change"><label for="actPrice">Price Change</label></div><div class="choice"><input type="checkbox" id="actUom" value="Change UOM"><label for="actUom">Change UOM</label></div><div class="choice"><input type="checkbox" id="actTerms" value="Change Incoterms"><label for="actTerms">Change Incoterms</label></div><div class="choice"><input type="checkbox" id="actCancel" value="Cancel SPA"><label for="actCancel">Cancel SPA</label></div></div></div>
          </div>
        </div>

        <div class="subsection">
          <h3>Commercial details</h3>
          <div class="grid">
            <div class="field"><label for="currency">Currency<span class="req">*</span></label><select id="currency"><option>USD</option><option>CAD</option><option>EUR</option><option>MXN</option></select></div>
            <div class="field"><label for="priority">Priority<span class="req">*</span></label><select id="priority"><option>Standard</option><option>Order pending / urgent</option><option>Month-end critical</option></select></div>
            <div class="field full"><label for="approvalNotes">Pricing approval / business rationale</label><textarea id="approvalNotes" placeholder="Who approved the pricing, why the change is needed, or relevant business context"></textarea></div>
          </div>
        </div>
        <div class="actions"><button class="btn btn-secondary" type="button" data-back>← Back</button><div class="actions-right"><button class="btn btn-primary" type="button" data-next>Next: Products →</button></div></div>
      </div>

      <div class="step" data-step="3">
        <div id="productSection">
          <div class="product-list" id="productList"></div>
          <button class="btn btn-secondary" type="button" id="addProduct">＋ Add another product</button>
        </div>
        <div id="cancelOnly" class="notice hidden"><div>ℹ️</div><div>Because <strong>Cancel SPA</strong> is selected without any product-level action, product details are optional. Continue to comments and review.</div></div>
        <div class="subsection">
          <div class="grid">
            <div class="field full"><label for="invoiceText">Invoice text</label><input id="invoiceText" placeholder="Enter N/A if not needed"></div>
            <div class="field full"><label for="comments">Special instructions / comments<span class="req">*</span></label><textarea id="comments" placeholder="State exactly what CET should do. Include order timing, products to remove, or other execution details." required></textarea></div>
          </div>
        </div>
        <div class="actions"><button class="btn btn-secondary" type="button" data-back>← Back</button><div class="actions-right"><button class="btn btn-primary" type="button" data-next>Review request →</button></div></div>
      </div>

      <div class="step" data-step="4">
        <div id="review"></div>
        <div class="subsection">
          <h3>Generated request</h3>
          <div id="summary" class="summary"></div>
        </div>
        <div id="success" class="success-box"><strong>Request prepared.</strong> Outlook should open with the formatted request. Review it, add any attachments, and send. For an official tracking reference, use Formsite.</div>
        <div class="actions"><button class="btn btn-secondary" type="button" data-back>← Back</button><div class="actions-right"><button class="btn btn-secondary" type="button" id="copyRequest">Copy request</button><a class="btn btn-secondary" href="https://fs27.formsite.com/NalcoWaterNA/nalco_landing/index.html" target="_blank" rel="noopener noreferrer">Open official Formsite</a><button class="btn btn-success" type="button" id="emailRequest">Open Outlook email</button></div></div>
      </div>
    </div>
  </section>
  <p class="footer-note">Draft data is stored only in this browser using local storage. Clear the form before using a shared computer. No data is transmitted by this page until you open and send the Outlook email or submit through Formsite.</p>
</main>

<script>
(function(){
'use strict';
const CONFIG={cetEmail:'GHTCET@ecolab.com',draftKey:'ctgCetDraftV1'};
let currentStep=1;
let productCounter=0;
const $=s=>document.querySelector(s);
const $$=s=>Array.from(document.querySelectorAll(s));
const titles={1:['Customer and requestor','Basic information used in the CET subject line and routing.'],2:['Request type and commercial details','Only questions relevant to the selected request are shown.'],3:['Products and instructions','Add only the products affected by this request.'],4:['Review and prepare','Confirm the request, then copy it, open Formsite, or prepare an Outlook email.']};

function todayISO(){const d=new Date();return d.toISOString().slice(0,10)}
function addMonths(date,months){const d=new Date(date+'T12:00:00');d.setMonth(d.getMonth()+months);return d.toISOString().slice(0,10)}
function endOfYear(){return new Date().getFullYear()+'-12-31'}
$('#effectiveDate').value=todayISO();$('#startDate').value=todayISO().slice(0,8)+'01';$('#endDate').value=endOfYear();

function escapeHtml(v){return String(v??'').replace(/[&<>'"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]))}
function requestKind(){return $('input[name="requestKind"]:checked').value}
function selectedActions(){return $$('#amendFields input[type="checkbox"]:checked').map(x=>x.value)}
function isCancelOnly(){const a=selectedActions();return requestKind()==='Amend Existing SPA'&&a.length===1&&a[0]==='Cancel SPA'}
function value(id){return $('#'+id).value.trim()}
function setValue(id,v){if($('#'+id))$('#'+id).value=v??''}

function showStep(n){
  currentStep=Math.max(1,Math.min(4,n));
  $$('.step').forEach(x=>x.classList.toggle('active',Number(x.dataset.step)===currentStep));
  $$('.progress button').forEach((b,i)=>{b.classList.toggle('active',i+1===currentStep);b.classList.toggle('done',i+1<currentStep)});
  $('#step-title').textContent=titles[currentStep][0];$('#step-subtitle').textContent=titles[currentStep][1];
  $('#validation').classList.remove('show');
  if(currentStep===4)buildReview();
  window.scrollTo({top:0,behavior:'smooth'});
}

function validateStep(n){
  const errors=[];
  if(n===1){
    [['requestorName','Your name'],['requestorEmail','Your email'],['soldTo','Sold-to number'],['accountName','Account name'],['incoterms','Incoterms']].forEach(([id,label])=>{if(!value(id))errors.push(label+' is required.')});
    if(value('requestorEmail')&&!$('#requestorEmail').checkValidity())errors.push('Enter a valid requestor email.');
    if(value('ccEmail')&&!$('#ccEmail').checkValidity())errors.push('Enter a valid CC email or leave it blank.');
  }
  if(n===2){
    if(requestKind()==='Amend Existing SPA'){
      if(!value('spaNumber'))errors.push('SPA number is required for an amendment.');
      if(!value('effectiveDate'))errors.push('Effective date is required.');
      if(!selectedActions().length)errors.push('Select at least one amendment action.');
    }
    if(requestKind()==='Setup New SPA'){
      if(!value('startDate'))errors.push('Start date is required.');
      if(!value('endDate'))errors.push('End date is required.');
    }
  }
  if(n===3){
    if(!isCancelOnly()){
      const rows=getProducts();
      if(!rows.length)errors.push('Add at least one product.');
      rows.forEach((p,i)=>{if(!p.material)errors.push('Product '+(i+1)+': product number is required.');if(!p.quantity)errors.push('Product '+(i+1)+': quantity is required.');if(p.action!=='Remove'&&!p.price)errors.push('Product '+(i+1)+': price is required unless the line is Remove.');});
    }
    if(!value('comments'))errors.push('Special instructions / comments are required.');
  }
  if(errors.length){$('#validation').innerHTML='<strong>Please fix the following:</strong><ul><li>'+errors.map(escapeHtml).join('</li><li>')+'</li></ul>';$('#validation').classList.add('show');return false}
  return true;
}

function updateBranching(){
  const kind=requestKind();
  $('#newFields').classList.toggle('hidden',kind!=='Setup New SPA');
  $('#amendFields').classList.toggle('hidden',kind!=='Amend Existing SPA');
  $('#cancelOnly').classList.toggle('hidden',!isCancelOnly());
  $('#productSection').classList.toggle('hidden',isCancelOnly());
  saveDraft();
}

function productTemplate(data={}){
  productCounter++;
  const id=productCounter;
  const row=document.createElement('div');row.className='product';row.dataset.id=id;
  row.innerHTML=`<div class="product-top"><h3>Product <span class="product-number"></span></h3><button type="button" class="btn btn-danger remove-product">Remove row</button></div><div class="product-grid">
  <div class="field"><label>Line action</label><select class="p-action"><option>Add</option><option>Remove</option><option>Price Change</option><option>Change UOM</option><option>No Change</option></select></div>
  <div class="field"><label>Product / package code<span class="req">*</span></label><input class="p-material" placeholder="6451.11"></div>
  <div class="field"><label>Annual quantity<span class="req">*</span></label><input class="p-qty" type="number" min="0" step="any" placeholder="1"></div>
  <div class="field"><label>Price basis</label><select class="p-uom"><option>EA</option><option>LB</option><option>GAL</option><option>KG</option></select></div>
  <div class="field"><label>Requested price</label><input class="p-price" type="number" min="0" step="0.0001" placeholder="0.00"></div>
  <div class="field"><label>Effective date</label><input class="p-date" type="date"></div></div>`;
  $('#productList').appendChild(row);
  row.querySelector('.p-action').value=data.action||'Add';row.querySelector('.p-material').value=data.material||'';row.querySelector('.p-qty').value=data.quantity||'';row.querySelector('.p-uom').value=data.uom||'EA';row.querySelector('.p-price').value=data.price||'';row.querySelector('.p-date').value=data.date||value('effectiveDate')||todayISO();
  row.querySelector('.remove-product').addEventListener('click',()=>{row.remove();renumberProducts();saveDraft()});
  row.querySelectorAll('input,select').forEach(el=>el.addEventListener('input',saveDraft));
  renumberProducts();
}
function renumberProducts(){ $$('#productList .product').forEach((r,i)=>r.querySelector('.product-number').textContent=i+1) }
function getProducts(){return $$('#productList .product').map(r=>({action:r.querySelector('.p-action').value,material:r.querySelector('.p-material').value.trim(),quantity:r.querySelector('.p-qty').value.trim(),uom:r.querySelector('.p-uom').value,price:r.querySelector('.p-price').value.trim(),date:r.querySelector('.p-date').value})).filter(p=>Object.values(p).some(Boolean))}

function collect(){return{requestorName:value('requestorName'),requestorEmail:value('requestorEmail'),district:value('district'),ccEmail:value('ccEmail'),soldTo:value('soldTo'),accountName:value('accountName'),government:value('government'),incoterms:value('incoterms'),requestKind:requestKind(),spaNumber:value('spaNumber'),effectiveDate:value('effectiveDate'),actions:selectedActions(),startDate:value('startDate'),endDate:value('endDate'),renew:value('renew'),spaType:value('spaType'),currency:value('currency'),priority:value('priority'),approvalNotes:value('approvalNotes'),invoiceText:value('invoiceText'),comments:value('comments'),products:getProducts()}}

function buildSummary(d){
  const lines=[];
  lines.push('CTG CET REQUEST','',`Requestor: ${d.requestorName}`,`Email: ${d.requestorEmail}`,`District: ${d.district}`,d.ccEmail?`Additional CC: ${d.ccEmail}`:'', '',`Sold-To: ${d.soldTo}`,`Account: ${d.accountName}`,`Government customer: ${d.government}`,`Incoterms: ${d.incoterms}`,`Currency: ${d.currency}`,'',`Request: ${d.requestKind}`);
  if(d.requestKind==='Amend Existing SPA')lines.push(`SPA Number: ${d.spaNumber}`,`Effective Date: ${d.effectiveDate}`,`Actions: ${d.actions.join(', ')}`);
  if(d.requestKind==='Setup New SPA')lines.push(`Start Date: ${d.startDate}`,`End Date: ${d.endDate}`,`Will Renew: ${d.renew}`,`SPA Type: ${d.spaType}`);
  lines.push(`Priority: ${d.priority}`,'');
  if(d.products.length){lines.push('PRODUCTS');d.products.forEach((p,i)=>lines.push(`${i+1}. ${p.action} | ${p.material} | Qty ${p.quantity} | ${p.uom} | ${p.action==='Remove'?'N/A':('$'+p.price+'/'+p.uom)} | ${p.date||'No date'}`));lines.push('')}
  lines.push('PRICING APPROVAL / BUSINESS RATIONALE',d.approvalNotes||'N/A','', 'INVOICE TEXT',d.invoiceText||'N/A','', 'SPECIAL INSTRUCTIONS / COMMENTS',d.comments||'N/A');
  return lines.filter((x,i,a)=>!(x===''&&a[i-1]==='')).join('\n');
}
function buildSubject(d){const ref='CTG-'+new Date().toISOString().slice(0,10).replaceAll('-','')+'-'+d.soldTo;return `${d.district} / ${d.requestKind.toUpperCase()} / ${d.accountName} / ${d.soldTo} / ${ref}`}
function buildReview(){
  const d=collect();const items=[['Requestor',d.requestorName],['District',d.district],['Sold-To',d.soldTo],['Account',d.accountName],['Request',d.requestKind],['SPA',d.spaNumber||'New / not assigned'],['Incoterms',d.incoterms],['Currency',d.currency],['Priority',d.priority]];
  let html='<div class="review-grid">'+items.map(([k,v])=>`<div class="review-item"><span>${escapeHtml(k)}</span><strong>${escapeHtml(v)}</strong></div>`).join('')+'</div>';
  if(d.products.length){html+='<div class="table-wrap"><table><thead><tr><th>Action</th><th>Product</th><th>Qty</th><th>Basis</th><th>Price</th><th>Effective</th></tr></thead><tbody>'+d.products.map(p=>`<tr><td>${escapeHtml(p.action)}</td><td>${escapeHtml(p.material)}</td><td>${escapeHtml(p.quantity)}</td><td>${escapeHtml(p.uom)}</td><td>${p.action==='Remove'?'N/A':escapeHtml('$'+p.price)}</td><td>${escapeHtml(p.date)}</td></tr>`).join('')+'</tbody></table></div>'}
  $('#review').innerHTML=html;$('#summary').textContent=buildSummary(d);saveDraft();
}

function saveDraft(){try{localStorage.setItem(CONFIG.draftKey,JSON.stringify(collect()))}catch(e){}}
function loadDraft(){
  try{const d=JSON.parse(localStorage.getItem(CONFIG.draftKey)||'null');if(!d)return;
    ['requestorName','requestorEmail','district','ccEmail','soldTo','accountName','government','incoterms','spaNumber','effectiveDate','startDate','endDate','renew','spaType','currency','priority','approvalNotes','invoiceText','comments'].forEach(id=>{if(d[id]!==undefined)setValue(id,d[id])});
    const radio=$(`input[name="requestKind"][value="${CSS.escape(d.requestKind||'Amend Existing SPA')}"]`);if(radio)radio.checked=true;
    $$('#amendFields input[type="checkbox"]').forEach(x=>x.checked=(d.actions||[]).includes(x.value));
    $('#productList').innerHTML='';(d.products&&d.products.length?d.products:[{}]).forEach(productTemplate);updateBranching();
  }catch(e){}
}

$$('[data-next]').forEach(b=>b.addEventListener('click',()=>{if(validateStep(currentStep))showStep(currentStep+1)}));
$$('[data-back]').forEach(b=>b.addEventListener('click',()=>showStep(currentStep-1)));
$$('[data-go]').forEach(b=>b.addEventListener('click',()=>{const n=Number(b.dataset.go);if(n<currentStep||validateStep(currentStep))showStep(n)}));
$$('input[name="requestKind"],#amendFields input[type="checkbox"]').forEach(x=>x.addEventListener('change',updateBranching));
$('#addProduct').addEventListener('click',()=>{productTemplate();saveDraft()});
$('#copyRequest').addEventListener('click',async()=>{try{await navigator.clipboard.writeText($('#summary').textContent);const b=$('#copyRequest');const old=b.textContent;b.textContent='Copied';setTimeout(()=>b.textContent=old,1200)}catch(e){alert('Copy was blocked by the browser. Select the generated request and copy it manually.')}});
$('#emailRequest').addEventListener('click',()=>{const d=collect();const subject=buildSubject(d);const body=buildSummary(d);const cc=d.ccEmail?`&cc=${encodeURIComponent(d.ccEmail)}`:'';window.location.href=`mailto:${CONFIG.cetEmail}?subject=${encodeURIComponent(subject)}${cc}&body=${encodeURIComponent(body)}`;$('#success').classList.add('show')});
$$('input,select,textarea').forEach(el=>el.addEventListener('input',saveDraft));

productTemplate();loadDraft();updateBranching();showStep(1);
})();
</script>
</body>
</html>
